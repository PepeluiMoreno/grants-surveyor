# Copia este fichero como .env y rellena los valores
# NUNCA subas .env al repositorio

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# OpenDataManager — configuración de conexión
# Opción A: URL completa (tiene prioridad si está definida)
# ODM_GRAPHQL_URL=http://optiplex-790:8040/graphql

# Opción B: partes individuales (se usan si ODM_GRAPHQL_URL no está definida)
ODM_API_SCHEME=http
ODM_API_HOST=optiplex-790
ODM_API_PORT=8040
ODM_GRAPHQL_PATH=/graphql

# Secreto HMAC para verificar webhooks entrantes de ODM
ODM_WEBHOOK_SECRET=cambia-esto-por-un-secreto-seguro
# Puerto donde GrantsSurveyor escucha los webhooks de ODM
ODM_WEBHOOK_PORT=8050

# Base de datos local
DATABASE_PATH=data/grants_surveyor.db

# Logging
LOG_LEVEL=INFO

# Umbrales de publicación (0.0 - 1.0)
DEFAULT_PUBLISH_THRESHOLD=0.85
DEFAULT_MIN_REVIEW_COVERAGE=0.70
